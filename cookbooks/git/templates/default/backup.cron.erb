#!/bin/bash

# DO NOT EDIT - This file is being maintained by Chef
set -euo pipefail

export ZSTD_CLEVEL=16

T=$(mktemp -d -t -p /var/tmp git.XXXXXXXXXX)
D=$(date +%Y-%m-%d)
B="git-$D.tar.zst"

ln -s /var/lib/git "$T/git-$D"

nice tar --create --dereference --directory="$T" \
  --sort=name \
  "git-$D" | nice zstd -T0 --quiet --long --rsyncable -o "$T/$B"

nice rsync --preallocate --fuzzy "$T/$B" backup.openstreetmap.org::backup

rm -rf "$T"
